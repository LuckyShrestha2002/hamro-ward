# Copy this file to ".env" and fill in your Supabase project values.
# Find them in the Supabase dashboard → Project Settings → API.
# The anon key is safe to expose in the browser (it is protected by Row Level
# Security policies defined in supabase/schema.sql).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

